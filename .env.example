# API base URL
# - Dev: leave empty — Vite proxies /api to VITE_API_PROXY_TARGET (avoids mixed content on HTTPS localhost)
# - Prod: set to the deployed backend origin, e.g. http://ec2-3-35-26-152.ap-northeast-2.compute.amazonaws.com
VITE_API_BASE_URL=

VITE_API_PROXY_TARGET=http://ec2-3-35-26-152.ap-northeast-2.compute.amazonaws.com

# Use mock API for local development (default: true when unset)
VITE_USE_MOCK_API=false

# Paramedic identifier sent with assignment requests
VITE_PARAMEDIC_ID=EMT-001

# Medical staff dashboard — hospital whose incoming patients are shown
VITE_HOSPITAL_ID=787337ac-d703-4480-b15a-916d7e2adae8

# Default map center for nearby-hospital ER status (Gangnam, Seoul)
VITE_DEFAULT_LATITUDE=37.4979
VITE_DEFAULT_LONGITUDE=127.0276

# Backend endpoints (OpenAPI):
# GET  /api/v1/health
# POST /api/v1/assignments
# GET  /api/v1/hospitals/nearby?latitude=&longitude=&limit=
# GET  /api/v1/hospitals/:hospital_id/patients
# GET  /api/v1/hospitals/:hospital_id/wait-time
